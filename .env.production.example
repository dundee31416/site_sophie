# Place a copy of this file at
#   /mnt/ssd_pool/apps_data/site_sophie/.env
# on the TrueNAS host, with real values, BEFORE pushing for the first deploy.
# docker compose reads it automatically from the working directory.

# ---- Postgres ----
POSTGRES_USER=lisons
POSTGRES_PASSWORD=__set_a_strong_password__
POSTGRES_DB=lisons

# ---- Web ----
# Port the host exposes for the public site. Behind a reverse proxy you can
# pick anything (e.g. 8081); without one, keep 80.
WEB_PORT=80

# Absolute public URL of the site, used for things like cookie scope and
# email/links in the future.
PUBLIC_BASE_URL=https://lisons.example.com

# ---- Auth ----
# Long random secret (32+ chars). Rotate by changing this value; existing
# sessions are invalidated.
#   e.g.  python -c 'import secrets;print(secrets.token_urlsafe(48))'
JWT_SECRET=__set_a_long_random_string__
JWT_EXPIRE_DAYS=7

# Initial admin account, seeded on first boot only (skipped on every
# subsequent boot). After first login, change the password via the API.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=__set_a_strong_password__

# ---- Cookie ----
# `true` requires the site to be served over HTTPS (cookies refused
# otherwise). Set to `false` only if the reverse proxy in front of you is
# plain HTTP.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_NAME=lisons_session

# ---- CORS ----
# Same-origin in the default setup (frontend nginx proxies /api to backend),
# so this can stay empty. Add an origin if you ever serve the SPA from a
# different host than the API.
CORS_ORIGINS=[]

# ---- Backups ----
# Nightly pg_dump files land in ./backups next to this file; dumps older
# than this many days are pruned automatically.
BACKUP_KEEP_DAYS=14

# ---- Gemini (optional) ----
# When set, the per-page Transcribe / Enhance / Restyle buttons in WorkEdit
# call Gemini Nano Banana. Get a key from https://aistudio.google.com/apikey.
# Image-edit requires the paid tier (free tier daily limit is 0).
# Leave empty to disable the AI buttons (returns 503).
GEMINI_API_KEY=
